HOST=0.0.0.0
PORT=8787

# Scheduler
AUTO_EXECUTE=0
MAX_CONCURRENCY=2
RETRY_LIMIT=2
RETRY_BACKOFF_MS=15000

# Executor mode: mock | openclaw
EXECUTOR_MODE=mock
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=
OPENCLAW_SPAWN_PATH=/sessions_spawn

# Notification webhook (optional)
NOTIFY_WEBHOOK_URL=

# RBAC (optional)
AUTH_ENABLED=0
USER_TOKEN=
ADMIN_TOKEN=
